      "@id": "aec:targetRule",
      "@type": "@id"
    },
    "environments": {
      "@id": "aec:environments",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "requestId": {
      "@id": "aec:requestId",
      "@type": "xsd:string"
    },
    "options": {
      "@id": "aec:options",
