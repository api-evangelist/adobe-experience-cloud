{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adobe-experience-cloud/refs/heads/main/json-structure/experience-platform-api-dataset-structure.json",
  "name": "Dataset",
  "description": "Dataset schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "schemaRef": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "contentType": {
          "type": "string"
        }
      }
    },
    "fileDescription": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string"
        }
      }
    },
    "created": {
      "type": "datetime"
    },
    "updated": {
      "type": "datetime"
    },
    "status": {
      "type": "string"
    }
  }
}