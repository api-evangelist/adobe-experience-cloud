{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adobe-experience-cloud/refs/heads/main/json-structure/target-api-activity-list-structure.json",
  "name": "ActivityList",
  "description": "ActivityList schema",
  "type": "object",
  "properties": {
    "total": {
      "type": "int32"
    },
    "offset": {
      "type": "int32"
    },
    "limit": {
      "type": "int32"
    },
    "activities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "int32"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "ab",
              "xt",
              "mvt",
              "ap"
            ]
          },
          "state": {
            "type": "string",
            "enum": [
              "approved",
              "deactivated",
              "archived"
            ]
          },
          "priority": {
            "type": "int32"
          },
          "modifiedAt": {
            "type": "datetime"
          },
          "startsAt": {
            "type": "datetime"
          },
          "endsAt": {
            "type": "datetime"
          }
        }
      }
    }
  }
}