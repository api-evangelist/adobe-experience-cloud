{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adobe-experience-cloud/refs/heads/main/json-structure/target-api-offer-list-structure.json",
  "name": "OfferList",
  "description": "OfferList schema",
  "type": "object",
  "properties": {
    "total": {
      "type": "int32"
    },
    "offset": {
      "type": "int32"
    },
    "limit": {
      "type": "int32"
    },
    "offers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "int32"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "content",
              "redirect",
              "dynamic"
            ]
          },
          "content": {
            "type": "string"
          },
          "modifiedAt": {
            "type": "datetime"
          }
        }
      }
    }
  }
}