{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adobe-experience-cloud/refs/heads/main/json-structure/experience-platform-api-schema-list-structure.json",
  "name": "SchemaList",
  "description": "SchemaList schema",
  "type": "object",
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "meta:altId": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      }
    },
    "_page": {
      "type": "object",
      "properties": {
        "count": {
          "type": "int32"
        }
      }
    }
  }
}