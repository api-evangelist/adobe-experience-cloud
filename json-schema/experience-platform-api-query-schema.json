{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adobe-experience-cloud/refs/heads/main/json-schema/experience-platform-api-query-schema.json",
  "title": "Query",
  "description": "Query schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "dbName": {
      "type": "string"
    },
    "sql": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "SUBMITTED",
        "IN_PROGRESS",
        "SUCCESS",
        "FAILED"
      ]
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "rowCount": {
      "type": "integer"
    }
  }
}