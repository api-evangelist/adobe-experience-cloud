{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adobe-experience-cloud/refs/heads/main/json-schema/target-api-offer-list-schema.json",
  "title": "OfferList",
  "description": "OfferList schema",
  "type": "object",
  "properties": {
    "total": {
      "type": "integer"
    },
    "offset": {
      "type": "integer"
    },
    "limit": {
      "type": "integer"
    },
    "offers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "content",
              "redirect",
              "dynamic"
            ]
          },
          "content": {
            "type": "string"
          },
          "modifiedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}