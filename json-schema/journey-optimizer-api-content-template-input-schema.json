{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adobe-experience-cloud/refs/heads/main/json-schema/journey-optimizer-api-content-template-input-schema.json",
  "title": "ContentTemplateInput",
  "description": "ContentTemplateInput schema",
  "type": "object",
  "required": [
    "name",
    "channel"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "channel": {
      "type": "string",
      "enum": [
        "email",
        "push",
        "sms",
        "inApp"
      ]
    },
    "content": {
      "type": "object"
    }
  }
}