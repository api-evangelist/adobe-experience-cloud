{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adobe-experience-cloud/refs/heads/main/json-schema/experience-platform-api-dataset-schema.json",
  "title": "Dataset",
  "description": "Dataset schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "schemaRef": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "contentType": {
          "type": "string"
        }
      }
    },
    "fileDescription": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string"
        }
      }
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string"
    }
  }
}